---
interface Props {
  title?: string;
  description?: string;
  variant?: 'light' | 'dark';
}

const {
  title = 'Ready to Modernize Your IT?',
  description = "Schedule a free consultation to discuss how Resolve Technology can help your business with reliable IT support, security, and compliance.",
  variant = 'dark'
} = Astro.props;

const isDark = variant === 'dark';
---

<section class:list={[
  'py-16 md:py-20',
  isDark ? 'bg-gradient-to-br from-resolve-blue to-resolve-teal' : 'bg-resolve-bg-soft'
]}>
  <div class="container-narrow text-center">
    <h2 class:list={[
      'text-3xl md:text-4xl font-bold mb-4',
      isDark ? 'text-white' : 'text-resolve-blue'
    ]}>
      {title}
    </h2>
    <p class:list={[
      'text-lg mb-8 max-w-2xl mx-auto',
      isDark ? 'text-white/80' : 'text-resolve-text-muted'
    ]}>
      {description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class:list={[
          'btn',
          isDark ? 'bg-white text-resolve-blue hover:bg-resolve-bg-soft' : 'btn-primary'
        ]}
      >
        Book Meeting
      </a>
      <a
        href="tel:603-742-1118"
        class:list={[
          'btn',
          isDark
            ? 'bg-white/10 text-white border border-white/20 hover:bg-white/20'
            : 'btn-secondary'
        ]}
      >
        Call (603) 742-1118
      </a>
    </div>
  </div>
</section>
