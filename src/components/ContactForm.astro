---
interface Props {
  formspreeId?: string;
}

const { formspreeId = 'xdawqlqg' } = Astro.props;
---

<form
  action={`https://formspree.io/f/${formspreeId}`}
  method="POST"
  class="space-y-6"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="name" class="block text-sm font-medium text-resolve-text mb-2">
        Name <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-3 rounded-lg border border-resolve-border focus:border-resolve-blue focus:ring-2 focus:ring-resolve-blue/20 outline-none transition-all"
        placeholder="Your name"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-resolve-text mb-2">
        Email <span class="text-red-500">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-lg border border-resolve-border focus:border-resolve-blue focus:ring-2 focus:ring-resolve-blue/20 outline-none transition-all"
        placeholder="you@company.com"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="phone" class="block text-sm font-medium text-resolve-text mb-2">
        Phone
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="w-full px-4 py-3 rounded-lg border border-resolve-border focus:border-resolve-blue focus:ring-2 focus:ring-resolve-blue/20 outline-none transition-all"
        placeholder="(555) 123-4567"
      />
    </div>

    <div>
      <label for="company" class="block text-sm font-medium text-resolve-text mb-2">
        Company
      </label>
      <input
        type="text"
        id="company"
        name="company"
        class="w-full px-4 py-3 rounded-lg border border-resolve-border focus:border-resolve-blue focus:ring-2 focus:ring-resolve-blue/20 outline-none transition-all"
        placeholder="Your company name"
      />
    </div>
  </div>

  <div>
    <label for="service" class="block text-sm font-medium text-resolve-text mb-2">
      Service Interest
    </label>
    <select
      id="service"
      name="service"
      class="w-full px-4 py-3 rounded-lg border border-resolve-border focus:border-resolve-blue focus:ring-2 focus:ring-resolve-blue/20 outline-none transition-all bg-white"
    >
      <option value="">Select a service (optional)</option>
      <option value="managed-it">Managed IT Services</option>
      <option value="cybersecurity">Cybersecurity</option>
      <option value="cloud">Cloud Services</option>
      <option value="backup">Backup & Recovery</option>
      <option value="compliance">Compliance (CMMC/NIST)</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-resolve-text mb-2">
      Message <span class="text-red-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 rounded-lg border border-resolve-border focus:border-resolve-blue focus:ring-2 focus:ring-resolve-blue/20 outline-none transition-all resize-none"
      placeholder="Tell us about your IT needs..."
    ></textarea>
  </div>

  <button type="submit" class="btn-primary w-full md:w-auto">
    Send Message
  </button>
</form>
