---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="card group block">
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 w-12 h-12 bg-resolve-bg-alt rounded-lg flex items-center justify-center group-hover:bg-resolve-teal/10 transition-colors">
      <Fragment set:html={icon} />
    </div>
    <div>
      <h3 class="text-lg font-semibold text-resolve-blue group-hover:text-resolve-teal transition-colors mb-2">
        {title}
      </h3>
      <p class="text-resolve-text-muted text-sm leading-relaxed">
        {description}
      </p>
      <span class="inline-flex items-center gap-1 text-resolve-teal text-sm font-medium mt-3 group-hover:gap-2 transition-all">
        Learn more
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
