---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Contact', href: '/contact' },
];

const serviceLinks = [
  { label: 'Managed IT', href: '/services/managed-it' },
  { label: 'Cybersecurity', href: '/services/cybersecurity' },
  { label: 'Cloud Services', href: '/services/cloud-services' },
  { label: 'Backup & Recovery', href: '/services/backup-recovery' },
  { label: 'Compliance', href: '/services/compliance' },
];
---

<footer class="bg-resolve-blue text-white">
  <div class="container-narrow py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <img src="/logo-white.png" alt="Resolve Technology" class="h-10 w-auto mb-4" />
        <p class="text-white/80 text-sm mb-4">
          Productivity and Security for Your Business. Corporate-level IT management for SMBs in Seacoast NH & New England.
        </p>
        <div class="flex items-center gap-2 mb-4">
          <img src="/veteran-badge.jpg" alt="U.S. Veteran Owned Business" class="h-12 w-auto rounded" />
          <span class="text-xs text-white/70">Veteran Owned</span>
        </div>
        <div class="flex flex-col gap-2 text-sm">
          <a href="tel:603-742-1118" class="text-white/80 hover:text-resolve-teal">
            (603) 742-1118
          </a>
          <a href="mailto:support@resolvetech.biz" class="text-white/80 hover:text-resolve-teal">
            support@resolvetech.biz
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/80 hover:text-resolve-teal text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold mb-4">Services</h4>
        <ul class="space-y-2">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/80 hover:text-resolve-teal text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contact Us</h4>
        <address class="not-italic text-white/80 text-sm mb-4">
          One New Hampshire Ave.<br />
          Suite 125<br />
          Portsmouth, NH 03801
        </address>
        <a href="/contact" class="btn bg-resolve-teal text-white hover:bg-white hover:text-resolve-blue text-sm">
          Book Meeting
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/20 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/60 text-sm">
        &copy; {currentYear} Resolve Technology LLC. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-white/60 hover:text-white text-sm">
          Privacy Policy
        </a>
      </div>
    </div>
  </div>
</footer>
